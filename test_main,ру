import unittest
from grooming_salon import GroomingSalon

class TestGroomingSalon(unittest.TestCase):

    def setUp(self):
        self.salon = GroomingSalon()

    def test_book_appointment_success(self):
        self.salon.book_appointment("John", "09:00", "Haircut", 30)
        expected_appointment = {
            "09:00": {
                "client_name": "John",
                "service": "Haircut",
                "duration": 30
            }
        }
        self.assertEqual(self.salon.get_appointments(), expected_appointment)

    def test_book_appointment_time_slot_already_booked(self):
        self.salon.book_appointment("John", "09:00", "Haircut", 30)
        with self.assertRaises(ValueError) as context:
            self.salon.book_appointment("Jane", "09:00", "Shave", 15)
        self.assertEqual(str(context.exception), "Time slot already booked")

    def test_cancel_appointment_success(self):
        self.salon.book_appointment("John", "09:00", "Haircut", 30)
        self.salon.cancel_appointment("09:00")
        self.assertEqual(self.salon.get_appointments(), {})

    def test_cancel_nonexistent_appointment(self):
        with self.assertRaises(ValueError) as context:
            self.salon.cancel_appointment("10:00")
        self.assertEqual(str(context.exception), "No appointment found at this time")

    def test_get_appointments_empty(self):
        self.assertEqual(self.salon.get_appointments(), {})

    def test_get_multiple_appointments(self):
        self.salon.book_appointment("John", "09:00", "Haircut", 30)
        self.salon.book_appointment("Jane", "10:00", "Nail Trim", 20)
        expected_appointments = {
            "09:00": {
                "client_name": "John",
                "service": "Haircut",
                "duration": 30
            },
            "10:00": {
                "client_name": "Jane",
                "service": "Nail Trim",
                "duration": 20
            }
        }


